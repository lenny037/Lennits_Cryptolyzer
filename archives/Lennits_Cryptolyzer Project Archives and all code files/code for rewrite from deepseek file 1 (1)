            padding: 12px 24px;
            border: none;
            border-radius: 10px;
            background: #f0f0f0;
            color: #666;
            font-size: 1em;
            cursor: pointer;
            transition: all 0.3s ease;
            font-weight: 600;
            flex: 1;
            min-width: 100px;
        }
        .format-btn:hover {
            background: #e0e0e0;
            transform: translateY(-2px);
        }
        .format-btn.active {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
        }
        .refresh-btn {
            width: 100%;
            padding: 15px;
            border: none;
            border-radius: 10px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            font-size: 1.2em;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-bottom: 20px;
            border: 2px solid transparent;
        }
        .refresh-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(102, 126, 234, 0.4);
            border-color: white;
        }
        .refresh-btn:disabled {
            opacity: 0.7;
            cursor: not-allowed;
            transform: none;
        }
        .status {
            text-align: center;
            color: #28a745;
            font-size: 0.9em;
            min-height: 20px;
        }
   
