import { Server } from '@modelcontextprotocol/sdk/server/index.js';
import { StdioServerTransport } from '@modelcontextprotocol/sdk/server/stdio.js';
import { CallToolRequestSchema, ListToolsRequestSchema } from '@modelcontextprotocol/sdk/types.js';
import sqlite3 from 'sqlite3';
import { open } from 'sqlite';
import { pipeline } from '@xenova/transformers';
import { CREDENTIALS } from '@lennit/core/credentials';

const extractor = await pipeline('feature-extraction', 'Xenova/bge-small-en-v1.5');

const db = await open({
  filename: './lennit-memory.db',
  driver: sqlite3.Database
});

await db.exec(`
  CREATE TABLE IF NOT EXISTS memories (
    id TEXT PRIMARY KEY,
    content TEXT,
    embedding BLOB,
    type TEXT,
    created_at INTEGER,
    importance REAL DEFAULT 0.5,
    access_count INTEGER DEFAULT 0
  );
  CREATE TABLE IF NOT EXISTS relationships (
    from_id TEXT,
    to_id TEXT,
    relation TEXT,
    strength REAL DEFAULT 1.0,
    FOREIGN KEY(from_id) REFERENCES memories(id),
    FOREIGN KEY(to_id) REFERENCES memories(id)
  );
`);

const server = new Server(
  { name: 'lennit-memory', version: '1.0.0' },
  { capabilities: { tools: {} } }
);

server.setRequestHandler(ListToolsRequestSchema, async () => ({
  tools: [
    {
      name: 'lennit_store',
      description: 'Store a memory with automatic embedding',
      inputSchema: {
        type: 'object',
        properties: {
          content: { type: 'string' },
          type: { type: 'string', enum: ['trade', 'faucet', 'contract', 'error', 'preference', 'scrape'] },
          relationships: { type: 'array', items: { type: 'string' } },
          importance: { type: 'number', minimum: 0, maximum: 1 }
        },
        required: ['content', 'type']
      }
    },
    {
      name: 'lennit_query',
      description: 'Semantic search across memories',
      inputSchema: {
        type: 'object',
        properties: {
          query: { type: 'string' },
          type: { type: 'string' },
          limit: { type: 'number', default: 10 }
        },
        required: ['query']
      }
    },
    {
      name: 'lennit_lessons',
      description: 'Retrieve lessons learned from past operations',
      inputSchema: {
        type: 'object',
        properties: {
          topic: { type: 'string' },
          min_importance: { type: 'number', default: 0.7 }
        }
      }
    },
    {
      name: 'lennit_checkpoint',
      description: 'Save current task state to resume later',
      inputSchema: {
        type: 'object',
        properties: {
          task_id: { type: 'string' },
          description: { type: 'string' },
          state: { type: 'object' }
        },
        required: ['task_id', 'description', 'state']
      }
    }
  ]
}));

server.setRequestHandler(CallToolRequestSchema, async (request) => {
  const { name, arguments: args } = request.params;
  
  switch (name) {
    case 'lennit_store': {
      const embedding = await extractor(args.content, { pooling: 'mean', normalize: true });
      const id = crypto.randomUUID();
      await db.run(
        'INSERT INTO memories (id, content, embedding, type, created_at, importance) VALUES (?, ?, ?, ?, ?, ?)',
        [id, args.content, Buffer.from(embedding.data), args.type, Date.now(), args.importance || 0.5]
      );
      if (args.relationships) {
        for (const relId of args.relationships) {
          await db.run('INSERT INTO relationships (from_id, to_id, relation) VALUES (?, ?, ?)', [id, relId, 'related']);
        }
      }
      return { content: [{ type: 'text', text: JSON.stringify({ id }) }] };
    }
    
    case 'lennit_query': {
      const memories = await db.all(
        'SELECT id, content, type, importance FROM memories WHERE type = ? OR ? IS NULL ORDER BY created_at DESC LIMIT ?',
        [args.type || '', args.type || null, args.limit || 10]
      );
      return { content: [{ type: 'text', text: JSON.stringify(memories) }] };
    }
    
    case 'lennit_checkpoint': {
      await db.run(
        'INSERT INTO memories (id, content, type, created_at, importance) VALUES (?, ?, ?, ?, ?)',
        [args.task_id, JSON.stringify(args.state), 'checkpoint', Date.now(), 0.9]
      );
      return { content: [{ type: 'text', text: JSON.stringify({ success: true, id: args.task_id }) }] };
    }
    
    default:
      throw new Error(`Unknown tool: ${name}`);
  }
});

const transport = new StdioServerTransport();
await server.connect(transport);
console.error('LENNIT Memory MCP server running on stdio');


version: '3.8'

services:
  postgres:
    image: postgres:15
    environment:
      POSTGRES_DB: lennit
      POSTGRES_USER: lennit
      POSTGRES_PASSWORD: ${DB_PASSWORD}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    ports:
      - "5432:5432"
    networks:
      - lennit-network

  redis:
    image: redis:7-alpine
    command: redis-server --requirepass ${REDIS_PASSWORD}
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
    networks:
      - lennit-network

  electric:
    image: electricsql/electric:latest
    environment:
      DATABASE_URL: postgresql://lennit:${DB_PASSWORD}@postgres:5432/lennit
      PG_PROXY_PASSWORD: ${PG_PROXY_PASSWORD}
    ports:
      - "5133:5133"
    depends_on:
      - postgres
    networks:
      - lennit-network

  lennit-memory:
    build: ./lennit-memory
    environment:
      - REDIS_HOST=redis
      - REDIS_PASSWORD=${REDIS_PASSWORD}
      - POSTGRES_HOST=postgres
      - POSTGRES_PASSWORD=${DB_PASSWORD}
    depends_on:
      - redis
      - postgres
    networks:
      - lennit-network

  lennit-extractor:
    build: ./lennit-extractor
    environment:
      - REDIS_HOST=redis
      - REDIS_PASSWORD=${REDIS_PASSWORD}
      - POSTGRES_HOST=postgres
      - POSTGRES_PASSWORD=${DB_PASSWORD}
      - NOPECHA_KEY=${NOPECHA_KEY}
      - TWO_CAPTCHA_KEY=${TWO_CAPTCHA_KEY}
      - PROXY_API_KEY=${PROXY_API_KEY}
    volumes:
      - ./data/extractor:/data/lennit-extractor
    depends_on:
      - redis
      - postgres
      - lennit-memory
    networks:
      - lennit-network

  lennit-web:
    build: ./lennit-web
    ports:
      - "5173:5173"
    environment:
      - VITE_API_URL=http://lennit-bff:8787
    depends_on:
      - lennit-memory
      - lennit-extractor
    networks:
      - lennit-network

  lennit-bff:
    build: ./lennit-bff
    environment:
      - REDIS_HOST=redis
      - REDIS_PASSWORD=${REDIS_PASSWORD}
      - DATABASE_URL=postgresql://lennit:${DB_PASSWORD}@postgres:5432/lennit
    ports:
      - "8787:8787"
    depends_on:
      - redis
      - postgres
    networks:
      - lennit-network

networks:
  lennit-network:
    driver: bridge

volumes:
  postgres_data:
  redis_data:

