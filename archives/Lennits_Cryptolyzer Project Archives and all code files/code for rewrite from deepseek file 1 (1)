use wasm_bindgen::prelude::*;
use serde::{Deserialize, Serialize};
use float_ord::FloatOrd;

#[derive(Deserialize)]
pub struct Ticker {
    pub exchange: String,
    pub base: String,
    pub quote: String,
    pub bid: f64,
    pub ask: f64,
}

#[derive(Serialize)]
pub struct Opportunity {
    pub id: String,
    pub base: String,
    pub quote: String,
    pub buy_exchange: String,
    pub sell_exchange: String,
    pub spread: f64,
}

#[wasm_bindgen]
pub fn find_opportunities(json: &str, min_spread: f64) -> String {
    let tickers: Vec<Ticker> = serde_json::from_str(json).unwrap_or_default();
    let mut result = Vec::new();
    
    for base in tickers.iter().map(|t| &t.base).collect::<std::collections::HashSet<_>>() {
        for quote in tickers.iter().map(|t| &t.quote).collect::<std::collections::HashSet<_>>() {
            let mut relevant: Vec<&Ticker> = tickers.iter()
                .filter(|t| &t.base == base && &t.quote == quote)
                .collect();
            
            if relevant.len() < 2 { continue; }
            
            relevant.sort_by_key(|t| FloatOrd(t.ask));
            let best_buy = relevant.first().unwrap();
            
            relevant.sort_by_key(|t| FloatOrd(-t.bid));
            let best_sell = relevant.first().unwrap();
            
            let spread = best_sell.bid / best_buy.ask - 1.0;
            if spread >= min_spread {
                result.push(Opportunity {
                    id: format!("{}-{}-{}-{}", base, quote, best_buy.exchange, best_sell.exchange),
                    base: base.to_string(),
                    quote: quote.to_string(),
                    buy_exchange: best_buy.exchange.clone(),
                    sell_exchange: best_sell.exchange.clone(),
                    spread,
                });
            }
        }
    }
    
    serde_json::to_string(&result).unwrap()
}

