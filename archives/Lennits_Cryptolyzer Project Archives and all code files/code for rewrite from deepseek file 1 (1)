import { McpServer } from "@modelcontextprotocol/sdk/server/mcp.js";
import { StreamableHTTPServerTransport } from "@modelcontextprotocol/sdk/server/streamableHttp.js";
import {
  registerAppTool,
  registerAppResource,
  RESOURCE_MIME_TYPE,
} from "@modelcontextprotocol/ext-apps/server";
import cors from "cors";
import express from "express";
import fs from "node:fs/promises";
import path from "node:path";
import { fileURLToPath } from "node:url";

const __dirname = path.dirname(fileURLToPath(import.meta.url));

const server = new McpServer({
  name: "LS.Technologies MCP Server",
  version: "1.0.0",
  description: "Interactive AI applications hosted at LS.Technologies",
});

const resourceUri = "ui://ls.technologies/mcp-app.html";

registerAppTool(
  server,
  "get-time",
  {
    title: "Get Current Time",
    description: "Returns the current server time in ISO format",
    inputSchema: {
      type: "object",
      properties: {
        format: {
          type: "string",
          enum: ["iso", "local", "unix"],
          description: "Time format to return"
        }
      }
    },
    _meta: { 
      ui: { 
        resourceUri,
        csp: "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline';"
      } 
    },
  },
  async (args: { format?: string }) => {
    const now = new Date();
    let time: string;
    
    switch(args.format) {
      case "local":
        time = now.toLocaleString();
        break;
      case "unix":
        time = now.getTime().toString();
        break;
      default:
        time = now.toISOString();
    }
    
    return {
      content: [{ 
        type: "text", 
        text: JSON.stringify({ 
          time, 
          format: args.format || "iso",
          timestamp: now.getTime()
        }) 
      }],
    };
  },
);

const randomResourceUri = "ui://ls.technologies/random-app.html";

registerAppTool(
  server,
  "generate-random",
  {
    title: "Generate Random Number",
    description: "Generates a random number within a range",
    inputSchema: {
      type: "object",
      properties: {
        min: { type: "number", default: 1 },
        max: { type: "number", default: 100 }
      }
    },
    _meta: { 
      ui: { 
        resourceUri: randomResourceUri,
        csp: "default-src 'self'; script-src 'self' 'unsafe-inline';"
      } 
    },
  },
  async (args: { min?: number; max?: number }) => {
    const min = args.min || 1;
    const max = args.max || 100;
    const random = Math.floor(Math.random() * (max - min + 1)) + min;
    
    return {
      content: [{ 
        type: "text", 
        text: JSON.stringify({ 
          value: random,
          min,
          max,
          timestamp: new Date().toISOString()
        }) 
      }],
    };
  },
);

registerAppResource(
  server,
  resourceUri,
  resourceUri,
  { 
    mimeType: RESOURCE_MIME_TYPE,
    description: "Interactive time display application"
  },
  async () => {
    try {
      const html = await fs.readFile(
        path.join(__dirname, "dist", "mcp-app.html"),
        "utf-8"
      );
      return {
        contents: [
          { 
            uri: resourceUri, 
            mimeType: RESOURCE_MIME_TYPE, 
            text: html 
          },
        ],
      };
    } catch (error) {
      console.error("Error reading HTML file:", error);
      return {
        contents: [{
          uri: resourceUri,
          mimeType: "text/plain",
          text: "Error loading application. Please ensure the build has been completed."
        }]
      };
    }
  },
);

registerAppResource(
  server,
  randomResourceUri,
  randomResourceUri,
  { 
    mimeType: RESOURCE_MIME_TYPE,
    description: "Interactive random number generator"
  },
  async () => {
    try {
      const html = await fs.readFile(
        path.join(__dirname, "dist", "random-app.html"), 
        "utf-8"
      );
      return {
        contents: [
          { 
            uri: randomResourceUri, 
            mimeType: RESOURCE_MIME_TYPE, 
            text: html 
          },
        ],
      };
    } catch (error) {
      const html = await fs.readFile(
        path.join(__dirname, "dist", "mcp-app.html"),
