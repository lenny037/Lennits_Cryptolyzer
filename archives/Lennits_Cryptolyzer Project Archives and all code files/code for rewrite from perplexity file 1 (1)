<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Lennits_Cryptolyzer | Intelligence Engineered</title>
    <!-- Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;800&family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --black-primary: #050505;
            --black-secondary: #0f0f0f;
            --red-glow: #ff1a1a;
            --red-deep: #8b0000;
            --copper: #b87333;
            --copper-light: #d49a5a;
            --text-light: #f5f5f5;
            --text-muted: #b5b5b5;
        }

        body {
            background: radial-gradient(circle at top right, #1a0000 0%, #000000 40%);
            font-family: 'Inter', sans-serif;
            color: var(--text-light);
            line-height: 1.6;
            scroll-behavior: smooth;
        }

        h1, h2, h3, h4 {
            font-family: 'Orbitron', sans-serif;
            letter-spacing: 1px;
        }

        /* Sticky Navigation */
        .sticky-nav {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: rgba(5, 5, 5, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(184, 115, 51, 0.4);
            padding: 0.75rem 8%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
        }

        .sticky-nav .logo {
            font-family: 'Orbitron', sans-serif;
            font-weight: 800;
            color: var(--copper-light);
            text-shadow: 0 0 10px var(--red-glow);
        }

        .nav-links {
            display: flex;
            gap: 2rem;
            flex-wrap: wrap;
        }

        .nav-links a {
            color: var(--text-muted);
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s;
        }

        .nav-links a:hover {
            color: var(--copper-light);
        }

        section {
            padding: 80px 8%;
            position: relative;
        }

        .container {
            max-width: 1400px;
            margin: auto;
        }

        /* Hero */
        .hero {
            text-align: center;
            padding: 100px 8% 80px 8%;
            background: linear-gradient(to bottom, #000000 0%, #0a0000 100%);
        }

        .hero h1 {
            font-size: 3.5rem;
            font-weight: 800;
            color: var(--copper-light);
            text-shadow: 0 0 20px var(--red-glow);
            animation: glowPulse 3s infinite;
        }

        @keyframes glowPulse {
            0% { text-shadow: 0 0 20px var(--red-glow); }
            50% { text-shadow: 0 0 35px var(--red-glow); }
            100% { text-shadow: 0 0 20px var(--red-glow); }
        }

        .hero .subtitle {
            font-size: 1.2rem;
            color: var(--copper);
            margin-top: 0.5rem;
            font-family: 'Orbitron', sans-serif;
        }

        .hero p {
            font-size: 1.2rem;
            color: var(--text-muted);
            max-width: 800px;
            margin: 30px auto;
        }

        /* Buttons */
        .btn {
            display: inline-block;
            padding: 12px 30px;
            border-radius: 30px;
            text-decoration: none;
            font-weight: 600;
            transition: 0.3s ease;
            cursor: pointer;
            border: none;
            font-size: 1rem;
        }

        .btn-primary {
            background: linear-gradient(45deg, var(--red-deep), var(--red-glow));
            color: white;
            border: 1px solid var(--copper);
            box-shadow: 0 0 20px rgba(255, 0, 0, 0.5);
        }

        .btn-primary:hover {
            box-shadow: 0 0 35px var(--red-glow);
            transform: translateY(-3px);
        }

        .btn-outline {
            background: transparent;
            border: 1px solid var(--copper);
            color: var(--copper-light);
        }

        .btn-outline:hover {
            background: rgba(184, 115, 51, 0.2);
            border-color: var(--red-glow);
            color: var(--red-glow);
            transform: translateY(-3px);
        }

        .btn-pdf {
            background: var(--black-secondary);
            border: 1px solid var(--copper);
            color: var(--text-light);
            margin-left: 1rem;
        }

        .btn-pdf:hover {
            border-color: var(--red-glow);
            color: var(--red-glow);
        }

        /* Card Grid */
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
        }

        .card {
            background: var(--black-secondary);
            border: 1px solid rgba(184, 115, 51, 0.4);
            padding: 30px;
            border-radius: 15px;
            transition: 0.3s ease;
        }

        .card:hover {
            border-color: var(--red-glow);
            box-shadow: 0 0 25px rgba(255, 0, 0, 0.4);
            transform: translateY(-5px);
        }

        .card h3 {
            color: var(--copper-light);
            margin-bottom: 15px;
        }

        .card ul, .card p {
            color: var(--text-muted);
        }

        .card ul {
            padding-left: 20px;
        }

        /* Section Titles */
        .section-title {
            text-align: center;
            margin-bottom: 60px;
        }

        .section-title h2 {
            font-size: 2.5rem;
            color: var(--copper);
            text-shadow: 0 0 12px rgba(255, 0, 0, 0.4);
        }

        .section-title p {
            color: var(--text-muted);
            max-width: 700px;
            margin: 1rem auto 0;
        }

        /* Architecture box */
        .architecture-box {
            background: var(--black-secondary);
            border: 1px solid var(--copper);
            padding: 50px;
            border-radius: 20px;
            box-shadow: 0 0 30px rgba(184, 115, 51, 0.3);
        }

        .architecture-box h3 {
            color: var(--copper-light);
            font-size: 2rem;
            margin-bottom: 2rem;
            text-align: center;
        }

        .plane-section {
            margin-bottom: 3rem;
            padding: 2rem;
            background: rgba(184, 115, 51, 0.05);
            border-left: 4px solid var(--copper);
            border-radius: 10px;
        }

        .plane-section h4 {
            color: var(--copper-light);
            font-size: 1.5rem;
            margin-bottom: 1rem;
        }

        .plane-section p {
            color: var(--text-muted);
            line-height: 1.8;
            margin-bottom: 1rem;
        }

        .plane-section .modules {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            margin-top: 1rem;
        }

        .module-tag {
            background: var(--black-primary);
            border: 1px solid var(--copper);
            color: var(--copper-light);
            padding: 0.4rem 1rem;
            border-radius: 20px;
            font-size: 0.85rem;
            font-family: 'Orbitron', sans-serif;
        }

        /* Timeline */
        .timeline {
            position: relative;
            padding-left: 2rem;
            max-width: 800px;
            margin: 0 auto;
        }

        .timeline-item {
            position: relative;
            padding-bottom: 2.5rem;
        }

        .timeline-item::before {
            content: '';
            position: absolute;
            left: -2rem;
            top: 0;
            width: 1rem;
            height: 1rem;
            border-radius: 50%;
            background: var(--red-glow);
            border: 2px solid var(--copper);
        }

        .timeline-item::after {
            content: '';
            position: absolute;
            left: -1.55rem;
            top: 1rem;
            width: 2px;
            height: 100%;
            background: var(--copper);
        }

        .timeline-item:last-child::after {
            display: none;
        }

        .timeline-date {
            font-weight: 700;
            color: var(--copper-light);
            margin-bottom: 0.5rem;
        }

        /* Table */
        .table-container {
            overflow-x: auto;
            margin-top: 2rem;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: var(--black-secondary);
            border-radius: 1rem;
            overflow: hidden;
            border: 1px solid rgba(184, 115, 51, 0.4);
        }

        th, td {
            padding: 1rem;
            text-align: left;
            border-bottom: 1px solid rgba(184, 115, 51, 0.2);
        }

        th {
            background: var(--black-primary);
            color: var(--copper-light);
            font-weight: 600;
        }

        code {
            background: #1e1e1e;
            padding: 0.2rem 0.4rem;
            border-radius: 4px;
        }

        /* Email Signup Form */
        .signup-form {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            justify-content: center;
            margin-top: 2rem;
        }

        .signup-form input {
            padding: 12px 20px;
            border-radius: 30px;
            border: 1px solid var(--copper);
            background: var(--black-secondary);
            color: var(--text-light);
            font-size: 1rem;
            min-width: 250px;
            flex: 1 1 250px;
        }

        .signup-form input::placeholder {
            color: var(--text-muted);
        }

        .signup-form input:focus {
            outline: none;
            border-color: var(--red-glow);
            box-shadow: 0 0 15px rgba(255, 0, 0, 0.3);
        }

        .success-message {
            color: var(--copper-light);
            margin-top: 1rem;
            font-weight: 600;
            display: none;
        }

        /* Social Icons */
        .social-icons {
            display: flex;
            gap: 1.5rem;
            justify-content: center;
            margin-top: 2rem;
        }

        .social-icons a {
            color: var(--text-muted);
            font-size: 1.8rem;
            transition: color 0.3s, transform 0.3s;
        }

        .social-icons a:hover {
            color: var(--copper-light);
            transform: translateY(-5px);
        }

        /* Footer */
        footer {
            background: black;
            padding: 50px 8% 30px;
            text-align: center;
            color: var(--text-muted);
            border-top: 1px solid rgba(184,115,51,0.4);
        }

        .legal-note {
            margin-top: 1rem;
            font-size: 0.9rem;
            color: var(--copper);
        }

        /* Responsive */
        @media (max-width: 768px) {
            .hero h1 { font-size: 2.5rem; }
            section { padding: 60px 5%; }
            .sticky-nav { flex-direction: column; gap: 0.5rem; }
            .nav-links { justify-content: center; gap: 1rem; }
        }
    </style>
</head>
