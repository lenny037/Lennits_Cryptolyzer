from fastapi import FastAPI, HTTPException
from pydantic import BaseModel
import numpy as np
from sentence_transformers import SentenceTransformer
import asyncpg
import os

app = FastAPI()
model = SentenceTransformer('all-MiniLM-L6-v2')
DATABASE_URL = os.getenv("DATABASE_URL", "postgresql://user:pass@localhost/mcp")

class Memory(BaseModel):
    content: str
    type: str
    importance: float = 0.5
    relationships: list[str] = []

@app.on_event("startup")
async def startup():
    app.state.pool = await asyncpg.create_pool(DATABASE_URL)
    async with app.state.pool.acquire() as conn:
        await conn.execute("""
            CREATE EXTENSION IF NOT EXISTS vector;
            CREATE TABLE IF NOT EXISTS memories (
                id SERIAL PRIMARY KEY,
                content TEXT,
                embedding vector(384),
                type TEXT,
                importance REAL,
                created_at TIMESTAMPTZ DEFAULT NOW()
            );
            CREATE TABLE IF NOT EXISTS relationships (
                from_id INT REFERENCES memories(id),
                to_id INT REFERENCES memories(id),
                relation TEXT,
                strength REAL DEFAULT 1.0
            );
        """)

@app.post("/memories")
async def create_memory(mem: Memory):
    embedding = model.encode(mem.content).tolist()
    async with app.state.pool.acquire() as conn:
        mem_id = await conn.fetchval("""
            INSERT INTO memories (content, embedding, type, importance)
            VALUES ($1, $2, $3, $4) RETURNING id
        """, mem.content, embedding, mem.type, mem.importance)
        for rel in mem.relationships:
            # Assume rel is an existing memory id
            await conn.execute("""
                INSERT INTO relationships (from_id, to_id, relation)
                VALUES ($1, $2, 'related')
            """, mem_id, int(rel))
        return {"id": mem_id}

@app.get("/search")
async def search(q: str, limit: int = 10):
    q_emb = model.encode(q).tolist()
    async with app.state.pool.acquire() as conn:
        rows = await conn.fetch("""
            SELECT id, content, type, importance,
                   1 - (embedding <=> $1) AS similarity
            FROM memories
            ORDER BY embedding <=> $1
            LIMIT $2
        """, q_emb, limit)
        return [dict(r) for r in rows]
