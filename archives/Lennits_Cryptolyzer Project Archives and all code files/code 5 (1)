contract AgentRegistry {
    struct Agent {
        address owner;
        string ipfsHash;      // code location
        uint256 reputation;
        uint256 createdAt;
        bool active;
    }

    mapping(bytes32 => Agent) public agents;  // agentId = keccak256(owner, codeHash)
    bytes32[] public agentList;

    event AgentRegistered(bytes32 indexed agentId, address owner, string ipfsHash);
    event ReputationUpdated(bytes32 indexed agentId, uint256 newRep);

    function registerAgent(string calldata ipfsHash) external returns (bytes32 agentId) {
        agentId = keccak256(abi.encodePacked(msg.sender, block.timestamp, ipfsHash));
        agents[agentId] = Agent(msg.sender, ipfsHash, 0, block.timestamp, true);
        agentList.push(agentId);
        emit AgentRegistered(agentId, msg.sender, ipfsHash);
    }

    function updateReputation(bytes32 agentId, uint256 delta) external {
        require(msg.sender == address(ReputationOracle), "Unauthorized");
        agents[agentId].reputation += delta;
        emit ReputationUpdated(agentId, agents[agentId].reputation);
    }
}
