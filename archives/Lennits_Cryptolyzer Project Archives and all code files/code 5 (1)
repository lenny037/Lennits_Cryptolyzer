3.2 Simple Trader Agent – trader.rs

```rust
use super::*;

pub struct TraderAgent {
    name: String,
    position: f64,
}

#[async_trait]
impl Agent for TraderAgent {
    async fn analyze(&self, ctx: &Context) -> Vec<Action> {
        // Example: simple moving average crossover
        let prices = &ctx.market_data;
        if prices.len() < 2 {
            return vec![];
        }
        let last = prices.last().unwrap().price;
        let prev = prices[prices.len() - 2].price;
        if last > prev {
            vec![Action {
                action_type: "buy".into(),
                params: serde_json::json!({ "amount": 0.1 }),
            }]
        } else {
            vec![]
        }
    }

    async fn execute(&mut self, action: &Action) -> Outcome {
        match action.action_type.as_str() {
            "buy" => {
                // Simulate trade
                self.position += action.params["amount"].as_f64().unwrap_or(0.0);
                Outcome {
                    success: true,
                    message: "Bought".into(),
                    data: serde_json::json!({ "new_position": self.position }),
                }
            }
            _ => Outcome {
                success: false,
                message: "Unknown action".into(),
                data: serde_json::Value::Null,
            },
        }
    }

    fn name(&self) -> &str {
        &self.name
    }
}
