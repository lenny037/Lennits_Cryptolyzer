fn select_validators(validators: Vec<Validator>, n: usize) -> Vec<Address> {
    // Weighted random selection by reputation
    let total_rep: u64 = validators.iter().map(|v| v.reputation).sum();
    let mut rng = rand::thread_rng();
    (0..n).map(|_| {
        let threshold = rng.gen_range(0..total_rep);
        let mut cumulative = 0;
        validators.iter().find(|v| {
            cumulative += v.reputation;
            cumulative >= threshold
        }).unwrap().id
    }).collect()
}
