3.3.2 QAOA Portfolio Optimizer (Python)

```python
# qaao_optimizer.py
import numpy as np
from qiskit import QuantumCircuit
from qiskit_algorithms import QAOA
from qiskit_algorithms.optimizers import COBYLA
from qiskit.primitives import Sampler
from qiskit_optimization import QuadraticProgram
from qiskit_optimization.converters import QuadraticProgramToQubo

class QAOAPortfolio:
    def __init__(self, returns, cov, n_assets):
        self.returns = returns
        self.cov = cov
        self.n = n_assets

    def build_problem(self, k):
        qp = QuadraticProgram()
        for i in range(self.n):
            qp.binary_var(f"x{i}")
        # Objective: maximize return - 0.5 * variance
        qp.maximize(
            linear={i: self.returns[i] for i in range(self.n)},
            quadratic={(i,j): -0.5 * self.cov[i][j] for i in range(self.n) for j in range(self.n)}
        )
        # Cardinality: exactly k assets
        qp.linear_constraint(
            linear={i:1 for i in range(self.n)},
            sense='==',
            rhs=k
        )
        return qp

    def optimize(self, k=5):
        qp = self.build_problem(k)
        qaoa = QAOA(sampler=Sampler(), optimizer=COBYLA(), reps=3)
        result = qaoa.compute_minimum_eigenvalue(qp.to_ising()[0])
        # decode result to bitstring
        return self._decode(result)
