class QuantumActorCritic:
    def __init__(self, n_qubits, n_actions):
        self.dev = qml.device('default.qubit', wires=n_qubits)
        self.weights = torch.randn(n_qubits, requires_grad=True)

        @qml.qnode(self.dev)
        def circuit(state):
            # encode state into qubits
            for i in range(n_qubits):
                qml.RY(state[i], wires=i)
            # variational layers
            for i in range(n_qubits):
                qml.RX(self.weights[i], wires=i)
            # measure expectation values
            return [qml.expval(qml.PauliZ(i)) for i in range(n_qubits)]

        self.circuit = circuit

    def forward(self, state):
        # classical preprocessing
        # quantum forward
        q_out = self.circuit(state)
        # classical postprocessing -> action probabilities
