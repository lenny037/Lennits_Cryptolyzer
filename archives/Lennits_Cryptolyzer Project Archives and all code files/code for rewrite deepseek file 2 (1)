import { McpServer } from "@modelcontextprotocol/sdk/server/mcp.js";
import { StreamableHTTPServerTransport } from "@modelcontextprotocol/sdk/server/streamableHttp.js";
import {
  registerAppTool,
  registerAppResource,
  RESOURCE_MIME_TYPE,
} from "@modelcontextprotocol/ext-apps/server";
import cors from "cors";
import express from "express";
import fs from "node:fs/promises";
import path from "node:path";
import { fileURLToPath } from "node:url";

const __dirname = path.dirname(fileURLToPath(import.meta.url));

const server = new McpServer({
  name: "LS.Technologies MCP Server",
  version: "1.0.0",
  description: "Interactive AI applications hosted at LS.Technologies",
});

const resourceUri = "ui://ls.technologies/mcp-app.html";

registerAppTool(
  server,
  "get-time",
  {
    title: "Get Current Time",
    description: "Returns the current server time in ISO format",
    inputSchema: {
      type: "object",
      properties: {
        format: {
          type: "string",
          enum: ["iso", "local", "unix"],
          description: "Time format to return"
        }
      }
    },
    _meta: { 
      ui: { 
        resourceUri,
        csp: "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline';"
      } 
    },
  },
  async (args: { format?: string }) => {
    const now = new Date();
    let time: string;
    
    switch(args.format) {
      case "local":
        time = now.toLocaleString();
        break;
      case "unix":
        time = now.getTime().toString();
        break;
      default:
        time = now.toISOString();
    }
    
    return {
      content: [{ 
        type: "text", 
        text: JSON.stringify({ 
          time, 
          format: args.format || "iso",
          timestamp: now.getTime()
        }) 
      }],
    };
  },
);

const randomResourceUri = "ui://ls.technologies/random-app.html";

registerAppTool(
  server,
  "generate-random",
  {
    title: "Generate Random Number",
    description: "Generates a random number within a range",
    inputSchema: {
      type: "object",
      properties: {
        min: { type: "number", default: 1 },
        max: { type: "number", default: 100 }
      }
    },
    _meta: { 
      ui: { 
        resourceUri: randomResourceUri,
        csp: "default-src 'self'; script-src 'self' 'unsafe-inline';"
      } 
    },
  },
  async (args: { min?: number; max?: number }) => {
    const min = args.min || 1;
    const max = args.max || 100;
    const random = Math.floor(Math.random() * (max - min + 1)) + min;
    
    return {
      content: [{ 
        type: "text", 
        text: JSON.stringify({ 
          value: random,
          min,
          max,
          timestamp: new Date().toISOString()
        }) 
      }],
    };
  },
);

registerAppResource(
  server,
  resourceUri,
  resourceUri,
  { 
    mimeType: RESOURCE_MIME_TYPE,
    description: "Interactive time display application"
  },
  async () => {
    try {
      const html = await fs.readFile(
        path.join(__dirname, "dist", "mcp-app.html"),
        "utf-8"
      );
      return {
        contents: [
          { 
            uri: resourceUri, 
            mimeType: RESOURCE_MIME_TYPE, 
            text: html 
          },
        ],
      };
    } catch (error) {
      console.error("Error reading HTML file:", error);
      return {
        contents: [{
          uri: resourceUri,
          mimeType: "text/plain",
          text: "Error loading application. Please ensure the build has been completed."
        }]
      };
    }
  },
);

registerAppResource(
  server,
  randomResourceUri,
  randomResourceUri,
  { 
    mimeType: RESOURCE_MIME_TYPE,
    description: "Interactive random number generator"
  },
  async () => {
    try {
      const html = await fs.readFile(
        path.join(__dirname, "dist", "random-app.html"), 
        "utf-8"
      );
      return {
        contents: [
          { 
            uri: randomResourceUri, 
            mimeType: RESOURCE_MIME_TYPE, 
            text: html 
          },
        ],
      };
    } catch (error) {
      const html = await fs.readFile(
        path.join(__dirname, "dist", "mcp-app.html"),
        "utf-8"
      );
      return {
        contents: [
          { 
            uri: randomResourceUri, 
            mimeType: RESOURCE_MIME_TYPE, 
            text: html 
          },
        ],
      };
    }
  },
);

const app = express();
app.use(cors());
app.use(express.json());

app.use(express.static(path.join(__dirname, "public")));

app.get("/health", (req, res) => {
  res.json({
    name: "LS.Technologies MCP Server",
    version: "1.0.0",
    status: "operational",
    endpoints: {
      mcp: "/mcp",
      health: "/health",
      website: "/"
    },
    tools: ["get-time", "generate-random"],
    documentation: "https://ls.technologies/docs"
  });
});

app.post("/mcp", async (req, res) => {
  const transport = new StreamableHTTPServerTransport({
    sessionIdGenerator: () => Math.random().toString(36).substring(7),
    enableJsonResponse: true,
  });
  
  res.on("close", () => transport.close());
  res.on("error", (err) => console.error("Response error:", err));
  
  try {
    await server.connect(transport);
    await transport.handleRequest(req, res, req.body);
  } catch (error) {
    console.error("Error handling MCP request:", error);
    if (!res.headersSent) {
      res.status(500).json({ error: "Internal server error" });
    }
  }
});

app.get("/docs", (req, res) => {
  res.send(`
    <html>
      <head><title>LS.Technologies MCP Documentation</title></head>
      <body>
        <h1>LS.Technologies MCP Server</h1>
        <p>Connect your MCP client to: <code>https://ls.technologies/mcp</code></p>
        <h2>Available Tools:</h2>
        <ul>
          <li><strong>get-time</strong> - Returns current server time</li>
          <li><strong>generate-random</strong> - Generates random numbers</li>
        </ul>
        <h2>Configuration Examples:</h2>
        <h3>Claude Desktop (with proxy):</h3>
        <pre>{
  "mcpServers": {
    "ls-technologies": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://ls.technologies/mcp"]
    }
  }
}</pre>
        <h3>VS Code/Copilot:</h3>
        <pre>{
  "servers": {
    "ls-technologies": {
      "type": "remote",
      "url": "https://ls.technologies/mcp"
    }
  }
}</pre>
        <p><a href="/">Back to LS.Technologies home</a></p>
      </body>
    </html>
  `);
});

const PORT = process.env.PORT || 3001;
app.listen(PORT, () => {
  console.log(`🚀 LS.Technologies MCP Server running on port ${PORT}`);
  console.log(`📡 MCP endpoint: http://localhost:${PORT}/mcp`);
  console.log(`🏠 Public website: http://localhost:${PORT}/`);
  console.log(`📊 Health check: http://localhost:${PORT}/health`);
  console.log(`📚 Docs: http://localhost:${PORT}/docs`);
});
EOF

