# ── Copy to .env — NEVER commit .env ────────────────────────────────────────
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY_HERE
BSC_RPC_URL=https://bsc-dataseed.binance.org/
POLYGON_RPC_URL=https://polygon-rpc.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
CHAIN_ID=1

# API Auth
LENNIT_API_KEY=your-secret-api-key-here
JWT_SECRET_KEY=your-256-bit-jwt-secret-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Trading
DEVIATION_THRESHOLD=5.0
POLL_INTERVAL_SECONDS=2.0
MAX_POSITION_SIZE_USD=10000
MIN_PROFIT_THRESHOLD_USD=5.0

# ML
MODEL_DIR=models/
FEATURE_WINDOW=50

# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/lennit_db

# Redis (rate limiting + caching)
REDIS_URL=redis://localhost:6379/0

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-api-key

# App
DEBUG=false
LOG_LEVEL=INFO
